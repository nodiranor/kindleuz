# ─── Run mode ────────────────────────────────────────────────────────────────
# polling = local dev (no domain/SSL needed); webhook = VPS deployment
MODE=polling

# ─── Telegram ──────────────────────────────────────────────────────────────--
BOT_TOKEN=123456789:AAExampleBotTokenFromBotFather

# ─── Webhook (only required when MODE=webhook) ─────────────────────────────────
WEBHOOK_BASE_URL=https://yourdomain.com
WEBHOOK_SECRET=change-me-to-a-random-32-char-string
WEBHOOK_PATH=/webhook
PORT=8001

# ─── SMTP (amerikadan.uz hosting mailbox) ──────────────────────────────────────
# Port 587 = STARTTLS (per your hosting). Some panels also offer 465 (implicit TLS).
SMTP_HOST=mail.amerikadan.uz
SMTP_PORT=587
SMTP_USER=ekitob@amerikadan.uz
SMTP_PASSWORD=your-mailbox-password
# Address users must whitelist at Amazon. Defaults to SMTP_USER if left blank.
SENDER_EMAIL=ekitob@amerikadan.uz
# Set false if the mail host's TLS cert doesn't match its hostname (shared
# hosting often serves the server's cert, not the mail.* alias). CA trust stays on.
SMTP_VERIFY_HOSTNAME=true

# ─── App ───────────────────────────────────────────────────────────────────--
# 20 MB — Telegram Bot API download cap. Amazon's own cap is 50 MB.
MAX_FILE_SIZE_BYTES=20971520
DATABASE_URL=sqlite+aiosqlite:///./kindle_bot.db
# Leave blank to use the OS temp dir. 0 in RATE_LIMIT_PER_DAY = unlimited.
TEMP_DIR=
RATE_LIMIT_PER_DAY=30


# /etc/nginx/sites-available/kindle_bot.conf
server {
    listen 443 ssl;
    server_name amerikadan.uz;

    ssl_certificate     /etc/letsencrypt/live/amerikadan.uz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/amerikadan.uz/privkey.pem;

    location = /webhook {                 # matches WEBHOOK_PATH exactly
        proxy_pass         http://127.0.0.1:8001;
        proxy_set_header   Host $host;
        client_max_body_size 1M;          # webhook JSON is tiny
    }
}